@page
@model ErrorModel
@{
    ViewData["Title"] = "خطا";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card error-card">
                <div class="card-body py-5">
                    <div class="error-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-2">خطایی رخ داد</h2>
                    <p class="text-muted mb-4">هنگام پردازش درخواست شما خطایی رخ داده است.</p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
                            <span class="fw-bold small">شناسه درخواست:</span>
                            <code class="small bg-light px-2 py-1 rounded">@Model.RequestId</code>
                        </div>
                    }

                    <div class="alert alert-info small text-start">
                        <i class="bi bi-info-circle"></i>
                        در محیط توسعه، اطلاعات جزئی‌تری از خطا نمایش داده می‌شود.
                        برای فعال‌سازی، متغیر محیطی <code>ASPNETCORE_ENVIRONMENT</code> را روی <code>Development</code> تنظیم کنید.
                    </div>

                    <a asp-page="/Index" class="btn btn-primary mt-3">
                        <i class="bi bi-house-fill"></i> بازگشت به خانه
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
