@page
@model ErrorModel
@{
    ViewData["Title"] = LErrors["Title"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card error-card">
                <div class="card-body py-5">
                    <div class="error-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-2">@LErrors["Generic.Heading"]</h2>
                    <p class="text-muted mb-4">@LErrors["Generic.Message"]</p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
                            <span class="fw-bold small">@LErrors["RequestId"]:</span>
                            <code class="small bg-light px-2 py-1 rounded">@Model.RequestId</code>
                        </div>
                    }

                    <div class="alert alert-info small text-start">
                        <i class="bi bi-info-circle"></i>
                        @LErrors["DevMode"]
                        @LErrors["DevMode.Hint"]
                    </div>

                    <a asp-page="/Index" class="btn btn-primary mt-3">
                        <i class="bi bi-house-fill"></i> @LErrors["ReturnHome"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
