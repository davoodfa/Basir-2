@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = LAuth["Register.Success"];
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <div class="app-logo"><i class="bi bi-diamond-fill"></i> @LLayout["Brand"]</div>
                <h2>@LAuth["Register.Success"]</h2>
            </div>
            <div class="card-body text-center">
                <div class="success-check mb-3">
                    <i class="bi bi-check-lg"></i>
                </div>
                <p class="mb-1 fw-bold">@LAuth["Register.Success.Message"]</p>
                <p class="text-muted small">
                    <i class="bi bi-envelope"></i>
                    @LAuth["Register.Success.EmailCheck"]
                    <br />
                    @LAuth["Register.Success.EmailCheckAfter"]
                </p>
                <div class="mt-4">
                    <a asp-page="/Account/Login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-left"></i> @LAuth["ConfirmEmail.Login"]
                    </a>
                </div>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="mt-3">
                        <form method="post" asp-page-handler="Resend" class="d-inline">
                            <input type="hidden" name="email" value="@Model.Email" />
                            <button type="submit" class="btn btn-link text-decoration-none small">
                                <i class="bi bi-arrow-repeat"></i> @LAuth["Register.ResendEmail"]
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
