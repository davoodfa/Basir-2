@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "بازیابی رمز عبور";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <div class="app-logo"><i class="bi bi-diamond-fill"></i> باسمه</div>
                <h2>بازیابی رمز عبور</h2>
                <p class="subtitle">ایمیل خود را وارد کنید، لینک بازنشانی برای شما ارسال خواهد شد</p>
            </div>
            <div class="card-body">
                @if (Model.Sent)
                {
                    <div class="text-center">
                        <div class="success-check mb-3">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <div class="alert alert-success">
                            <i class="bi bi-envelope-check"></i>
                            اگر حسابی با این ایمیل وجود داشته باشد، لینک بازنشانی رمز عبور برای شما ارسال شده است.
                        </div>
                        <a asp-page="/Account/Login" class="btn btn-outline-primary mt-2">
                            <i class="bi bi-box-arrow-in-left"></i> بازگشت به صفحه ورود
                        </a>
                    </div>
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control" placeholder="example@email.com" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope"></i> ایمیل</label>
                            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-send"></i> ارسال لینک بازنشانی
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-page="/Account/Login" class="text-decoration-none small">
                            <i class="bi bi-arrow-right"></i> بازگشت به صفحه ورود
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
