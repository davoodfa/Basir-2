@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = LAuth["ForgotPassword.Title"];
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <div class="app-logo"><i class="bi bi-diamond-fill"></i> @LLayout["Brand"]</div>
                <h2>@LAuth["ForgotPassword.Title"]</h2>
                <p class="subtitle">@LAuth["ForgotPassword.Subtitle"]</p>
            </div>
            <div class="card-body">
                @if (Model.Sent)
                {
                    <div class="text-center">
                        <div class="success-check mb-3">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <div class="alert alert-success">
                            <i class="bi bi-envelope-check"></i>
                            @LAuth["ForgotPassword.Success"]
                        </div>
                        <a asp-page="/Account/Login" class="btn btn-outline-primary mt-2">
                            <i class="bi bi-box-arrow-in-left"></i> @LAuth["ForgotPassword.ReturnToLogin"]
                        </a>
                    </div>
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control" placeholder="@LAuth["Login.Placeholder.Email"]" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope"></i> @LAuth["ForgotPassword.Email"]</label>
                            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-send"></i> @LAuth["ForgotPassword.Submit"]
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-page="/Account/Login" class="text-decoration-none small">
                            <i class="bi bi-arrow-right"></i> @LAuth["ForgotPassword.ReturnToLogin"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
