@page
@model LogoutModel
@{
    ViewData["Title"] = "خروج";
}

<div class="auth-page">
    <div class="auth-card slide-up">
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status" style="width:3rem;height:3rem;border-width:0.2em;">
                    <span class="visually-hidden">در حال خروج...</span>
                </div>
                <h4>در حال خروج از حساب کاربری...</h4>
                <p class="text-muted small"><i class="bi bi-clock"></i> لطفاً صبر کنید</p>
            </div>
        </div>
    </div>
</div>
