@page
@model LogoutModel
@{
    ViewData["Title"] = LAuth["Logout.Title"];
}

<div class="auth-page">
    <div class="auth-card slide-up">
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status" style="width:3rem;height:3rem;border-width:0.2em;">
                    <span class="visually-hidden">@LAuth["Logout.Spinner"]</span>
                </div>
                <h4>@LAuth["Logout.Leaving"]</h4>
                <p class="text-muted small"><i class="bi bi-clock"></i> @LAuth["Logout.Wait"]</p>
            </div>
        </div>
    </div>
</div>
