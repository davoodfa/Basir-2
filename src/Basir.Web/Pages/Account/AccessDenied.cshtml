@page
@{
    ViewData["Title"] = "عدم دسترسی";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card error-card">
            <div class="card-body py-5">
                <div class="error-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h2 class="fw-bold mb-2">دسترسی محدود</h2>
                <p class="text-muted mb-4">شما مجوز مشاهده این صفحه را ندارید.</p>
                <a asp-page="/Index" class="btn btn-primary">
                    <i class="bi bi-house-fill"></i> بازگشت به خانه
                </a>
            </div>
        </div>
    </div>
</div>
