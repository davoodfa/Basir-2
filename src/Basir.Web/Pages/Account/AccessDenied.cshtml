@page
@{
    ViewData["Title"] = LAuth["AccessDenied.Title"];
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card error-card">
            <div class="card-body py-5">
                <div class="error-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h2 class="fw-bold mb-2">@LAuth["AccessDenied.Heading"]</h2>
                <p class="text-muted mb-4">@LAuth["AccessDenied.Message"]</p>
                <a asp-page="/Index" class="btn btn-primary">
                    <i class="bi bi-house-fill"></i> @LAuth["AccessDenied.ReturnHome"]
                </a>
            </div>
        </div>
    </div>
</div>
