@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = LAuth["ConfirmEmail.Title"];
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <div class="app-logo"><i class="bi bi-diamond-fill"></i> @LLayout["Brand"]</div>
                <h2>@LAuth["ConfirmEmail.Title"]</h2>
            </div>
            <div class="card-body text-center">
                @if (Model.Succeeded)
                {
                    <div class="success-check mb-3">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <div class="alert alert-success">
                        <i class="bi bi-envelope-check"></i>
                        @LAuth["ConfirmEmail.Success"]
                    </div>
                    <a asp-page="/Account/Login" class="btn btn-primary mt-2">
                        <i class="bi bi-box-arrow-in-left"></i> @LAuth["ConfirmEmail.Login"]
                    </a>
                }
                else if (Model.Invalid)
                {
                    <div class="mb-3" style="font-size:3.5rem;color:#ef4444;">
                        <i class="bi bi-x-octagon-fill"></i>
                    </div>
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i>
                        @LAuth["ConfirmEmail.Failure"]
                    </div>
                    <a asp-page="/Account/Register" class="btn btn-outline-primary mt-2">
                        <i class="bi bi-person-plus"></i> @LAuth["ConfirmEmail.RegisterAgain"]
                    </a>
                }
                else
                {
                    <div class="d-flex justify-content-center py-4">
                        <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                            <span class="visually-hidden">@LAuth["ConfirmEmail.Spinner"]</span>
                        </div>
                    </div>
                    <p class="text-muted">@LAuth["ConfirmEmail.Verifying"]</p>
                }
            </div>
        </div>
    </div>
</div>
