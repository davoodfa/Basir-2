@page
@model ResetPasswordModel
@{
    ViewData["Title"] = LAuth["ResetPassword.Title"];
}

<div class="auth-page">
    <div class="auth-card">
        <div class="card">
            <div class="card-header">
                <div class="app-logo"><i class="bi bi-diamond-fill"></i> @LLayout["Brand"]</div>
                <h2>@LAuth["ResetPassword.Title"]</h2>
                <p class="subtitle">@LAuth["ResetPassword.Subtitle"]</p>
            </div>
            <div class="card-body">
                @if (Model.Done)
                {
                    <div class="text-center">
                        <div class="success-check mb-3">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <div class="alert alert-success">
                            <i class="bi bi-shield-check"></i>
                            @LAuth["ResetPassword.Success"]
                        </div>
                        <a asp-page="/Account/Login" class="btn btn-primary mt-2">
                            <i class="bi bi-box-arrow-in-left"></i> @LAuth["ResetPassword.Login"]
                        </a>
                    </div>
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <input type="hidden" asp-for="Input.Email" />
                        <input type="hidden" asp-for="Input.Token" />

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.NewPassword" class="form-control" placeholder="@LAuth["ResetPassword.Placeholder"]" id="reset-password" />
                            <label asp-for="Input.NewPassword"><i class="bi bi-lock"></i> @LAuth["ResetPassword.NewPassword"]</label>
                            <button type="button" class="password-toggle" data-pw-toggle="reset-password" tabindex="-1" aria-label="@LAuth["Login.PasswordToggle"]">
                                <i class="bi bi-eye"></i>
                            </button>
                            <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="@LAuth["ResetPassword.Placeholder"]" id="reset-confirm" />
                            <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock"></i> @LAuth["ResetPassword.ConfirmPassword"]</label>
                            <button type="button" class="password-toggle" data-pw-toggle="reset-confirm" tabindex="-1" aria-label="@LAuth["Login.PasswordToggle"]">
                                <i class="bi bi-eye"></i>
                            </button>
                            <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-arrow-repeat"></i> @LAuth["ResetPassword.Submit"]
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
