@page
@model IndexModel
@{
    ViewData["Title"] = LNav["Home"];
}

<div class="hero-section">
    <div class="container">
        <div class="hero-icon">
            <i class="bi bi-diamond-fill"></i>
        </div>
        <h1>@L["Common.Welcome", LLayout["Brand"]]</h1>
        <p>@L["Common.Subtitle"]</p>

        @if (!(User.Identity?.IsAuthenticated ?? false))
        {
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a asp-page="/Account/Register" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-person-plus"></i> @LNav["Register"]
                </a>
                <a asp-page="/Account/Login" class="btn btn-outline-primary btn-lg px-4">
                    <i class="bi bi-box-arrow-in-left"></i> @LNav["Login"]
                </a>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a asp-page="/Manage/Index" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-person-gear"></i> @LAuth["Manage.Title"]
                </a>
            </div>
        }
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-12 col-md-4">
            <div class="card feature-card slide-up" style="animation-delay:0.1s;">
                <div class="card-body">
                    <div class="card-icon"><i class="bi bi-shield-check"></i></div>
                    <h5 class="card-title">@L["Common.Feature.Security.Title"]</h5>
                    <p class="card-text">@L["Common.Feature.Security.Desc"]</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card feature-card slide-up" style="animation-delay:0.2s;">
                <div class="card-body">
                    <div class="card-icon"><i class="bi bi-lightning-charge"></i></div>
                    <h5 class="card-title">@L["Common.Feature.Speed.Title"]</h5>
                    <p class="card-text">@L["Common.Feature.Speed.Desc"]</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card feature-card slide-up" style="animation-delay:0.3s;">
                <div class="card-body">
                    <div class="card-icon"><i class="bi bi-devices"></i></div>
                    <h5 class="card-title">@L["Common.Feature.Responsive.Title"]</h5>
                    <p class="card-text">@L["Common.Feature.Responsive.Desc"]</p>
                </div>
            </div>
        </div>
    </div>
</div>
