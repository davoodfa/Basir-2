@page
@model Basir.Web.Pages.Manage.ChangePasswordModel
@{
    ViewData["Title"] = LAuth["ChangePassword.Title"];
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item"><a asp-page="/Manage/Index" class="text-decoration-none">@LAuth["Breadcrumb.ManageAccount"]</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@LAuth["Breadcrumb.ChangePassword"]</li>
                </ol>
            </nav>

            @if (Model.Done)
            {
                <div class="card manage-card">
                    <div class="card-body text-center py-5">
                        <div class="success-check mb-3">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h5 class="fw-bold mb-2">@LAuth["ChangePassword.Success"]</h5>
                        <p class="text-muted small mb-4">@LAuth["ChangePassword.Success.Desc"]</p>
                        <a asp-page="/Manage/Index" class="btn btn-primary">
                            <i class="bi bi-arrow-right"></i> @LAuth["ChangePassword.Return"]
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="card manage-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-4">
                            <i class="bi bi-key" style="font-size:1.5rem;color:var(--bs-primary);"></i>
                            <h4 class="mb-0 fw-bold">@LAuth["ChangePassword.Title"]</h4>
                        </div>

                        <form method="post">
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                            <div class="form-floating mb-3 position-relative">
                                <input asp-for="Input.CurrentPassword" class="form-control" placeholder="@LAuth["ChangePassword.Placeholder.Current"]" id="cp-current" />
                                <label asp-for="Input.CurrentPassword"><i class="bi bi-lock"></i> @LAuth["ChangePassword.CurrentPassword"]</label>
                                <button type="button" class="password-toggle" data-pw-toggle="cp-current" tabindex="-1" aria-label="@LAuth["Login.PasswordToggle"]">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <span asp-validation-for="Input.CurrentPassword" class="field-validation-error"></span>
                            </div>

                            <div class="form-floating mb-3 position-relative">
                                <input asp-for="Input.NewPassword" class="form-control" placeholder="@LAuth["ChangePassword.Placeholder.New"]" id="cp-new" />
                                <label asp-for="Input.NewPassword"><i class="bi bi-lock"></i> @LAuth["ChangePassword.NewPassword"]</label>
                                <button type="button" class="password-toggle" data-pw-toggle="cp-new" tabindex="-1" aria-label="@LAuth["Login.PasswordToggle"]">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
                            </div>

                            <div class="form-floating mb-4 position-relative">
                                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="@LAuth["ChangePassword.Placeholder.Confirm"]" id="cp-confirm" />
                                <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock"></i> @LAuth["ChangePassword.ConfirmPassword"]</label>
                                <button type="button" class="password-toggle" data-pw-toggle="cp-confirm" tabindex="-1" aria-label="@LAuth["Login.PasswordToggle"]">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 btn-lg">
                                <i class="bi bi-check-lg"></i> @LAuth["ChangePassword.Submit"]
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
