@page
@model PrivacyModel
@{
    ViewData["Title"] = L["Common.Privacy.Title"];
}

<div class="container py-4">
    <div class="card page-card fade-in">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-3">
                <i class="bi bi-shield-lock" style="font-size:1.5rem;color:var(--bs-primary);"></i>
                <h2 class="fw-bold mb-0">@ViewData["Title"]</h2>
            </div>
            <p class="text-muted">@L["Common.Privacy.Intro"]</p>
            <hr />
            <h5 class="fw-bold">@L["Common.Privacy.DataCollected"]</h5>
            <p class="text-muted">@L["Common.Privacy.DataCollected.Desc"]</p>
            <h5 class="fw-bold">@L["Common.Privacy.DataUsage"]</h5>
            <p class="text-muted">@L["Common.Privacy.DataUsage.Desc"]</p>
            <h5 class="fw-bold">@L["Common.Privacy.DataSecurity"]</h5>
            <p class="text-muted">@L["Common.Privacy.DataSecurity.Desc"]</p>
        </div>
    </div>
</div>
